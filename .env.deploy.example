# Настройки FTP для деплоя
# Скопируйте этот файл в .env.deploy и заполните реальными данными

# FTP хост
FTP_HOST=server295.hosting.reg.ru

# FTP пользователь
FTP_USER=u3156202_deploy

# FTP пароль
FTP_PASSWORD=your_password_here

# Директория на сервере (обычно / или /www/yoursite.com)
FTP_DIR=/

# Опционально: порт FTP (по умолчанию 21)
# FTP_PORT=21
